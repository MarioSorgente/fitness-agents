# Public app URL used for absolute links and redirects.
# Example: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# Shows the intake test helper in production when explicitly set to true.
# In local development the helper appears automatically because NODE_ENV !== production.
NEXT_PUBLIC_ENABLE_TEST_INTAKE=

# Coaching repository mode. Use local for development without Firestore, or firebase to require Firestore.
# If unset, complete Firebase Admin credentials select Firestore; local development without credentials falls back to local JSON storage.
COACHING_REPOSITORY=
COACHING_LOCAL_STORE_PATH=

# Admin-only API/page access key. Required for /api/coaching/test-orchestration.
ADMIN_ACCESS_KEY=

# Preferred premium synthesis provider for final-moderator work.
# Expected values may include: openai, anthropic, kimi.
# AI_PROVIDER=anthropic means the final moderator prefers Anthropic Opus first.
# Cheap expert-panel steps still use Kimi/OpenAI fast models before Anthropic fast models.
# Fallback order is per task tier, so Opus is not used for every subtask.
AI_PROVIDER=

# OpenAI configuration.
# Server-only secret; do not expose this value in client-side code.
OPENAI_API_KEY=
# Main/high-quality OpenAI model for complex coaching work.
OPENAI_MODEL_MAIN=
# Fast/lower-latency OpenAI model for lightweight work. Test mode defaults to gpt-4.1-nano when unset.
OPENAI_MODEL_FAST=

# Anthropic configuration.
# Server-only secret; do not expose this value in client-side code.
ANTHROPIC_API_KEY=
# Main/high-quality Anthropic model for complex coaching work.
ANTHROPIC_MODEL_MAIN=
# Fast/lower-latency Anthropic model for lightweight work.
ANTHROPIC_MODEL_FAST=

# Kimi configuration.
# Server-only secret; do not expose this value in client-side code.
KIMI_API_KEY=
# Main/high-quality Kimi model for complex coaching work.
KIMI_MODEL_MAIN=
# Fast/lower-latency Kimi model for lightweight work.
KIMI_MODEL_FAST=

# Firebase public client configuration.
# These NEXT_PUBLIC_* values are safe to expose to the browser.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin server configuration.
# Option 1: provide the full service-account JSON as a single string.
FIREBASE_SERVICE_ACCOUNT_KEY=
# Option 2: provide the service-account fields separately.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Store newline characters as escaped \n when your host requires single-line env vars.
FIREBASE_PRIVATE_KEY=
# Option 3: omit the credential fields above and set this path in your hosting environment
# so Firebase Admin can use application default credentials.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional future PDF storage bucket.
# Intentionally unused for v1 because PDFs are download-only.
PDF_STORAGE_BUCKET=
