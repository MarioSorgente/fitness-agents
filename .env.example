# Firebase Admin SDK (server-only)
# Option A: provide one JSON string with project_id, client_email, and private_key.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Option B: provide individual service-account fields instead of FIREBASE_SERVICE_ACCOUNT_KEY.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Option C: omit the credential fields above and set GOOGLE_APPLICATION_CREDENTIALS
# in your hosting environment so Firebase Admin can use application default credentials.
GOOGLE_APPLICATION_CREDENTIALS=
